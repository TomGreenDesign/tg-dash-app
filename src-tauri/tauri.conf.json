{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "TG Dash",
  "version": "0.2.1",
  "identifier": "uk.tomgreen.dash",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TG Dash",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)|(tg-dash://\\w*)|(tg-docs://\\w*)).+"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["tg-dash"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/TomGreenDesign/tg-dash-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCOEI2MzUwRDYzRjA2RDEKUldUUkJqL1dVR09MVysrSVlJbzFNT20xRWxYRFR2WVZUMWpVTW93aHZzdW41ZzRaZFVzNTVFZHUK"
    }
  }
}
